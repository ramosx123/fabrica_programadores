programa {
  funcao inicio() {
     inteiro a,b
     escreva("digite o primeiro valor: ")
     leia(a)
     escreva("digite o segundo valor: ")
     leia(b)
     escreva("---comparação---")
     escreva(" a > b = ", (a>b),"\n")
     escreva ("a >= b = ",(a>=b), "\n")
     escreva(" a < b = ", (a<b),"\n")
     escreva(" a <= b = ", (a<=b),"\n")
     escreva(" a ! b = ", (a!b),"\n")
     
  }
}
